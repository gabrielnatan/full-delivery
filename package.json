{
  "name": "full-delivery",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma nacional de entregas — monorepo",
  "scripts": {
    "dev:gateway": "npm run dev -w api-gateway",
    "build:all": "npm run build --workspaces --if-present",
    "test:all": "npm run test --workspaces --if-present",
    "lint": "eslint \"services/**/*.ts\" \"packages/**/*.ts\" --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielnatan/full-delivery.git"
  },
  "license": "ISC",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5"
  }
}
