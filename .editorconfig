# EditorConfig — alinha indentação entre VS Code, Cursor, WebStorm, etc.
# Ver docs/05-ops/padrao-codigo-monorepo.md

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
